{
  "name": "resume-ai",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "expose": "ng serve --host 0.0.0.0",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "format:check": "prettier --check \"src/**/*.{json,css,scss,md,ts,html}\"",
    "format": "prettier --write \"src/**/*.{json,css,scss,md,ts,html}\""
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular-devkit/core": "^21.2.3",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@primeuix/themes": "^2.0.3",
    "@stomp/stompjs": "^7.3.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.1.0",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.0.0",
    "rxjs": "~7.8.0",
    "sockjs-client": "^1.6.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/sockjs-client": "^1.5.4",
    "jest": "^30.0.0",
    "jest-preset-angular": "^16.1.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "glob": "^13.0.6",
    "undici": "^7.24.5"
  }
}
